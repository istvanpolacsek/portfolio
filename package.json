{
  "name": "portfolio",
  "packageManager": "yarn@4.12.0",
  "devDependencies": {
    "@commitlint/cli": "20.4.3",
    "@commitlint/config-conventional": "20.4.3",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@nx/eslint": "22.5.2",
    "browserslist": "4.28.1",
    "eslint": "9.39.3",
    "husky": "9.1.7",
    "lint-staged": "16.3.2",
    "nx": "22.5.2",
    "prettier": "3.8.1",
    "stylelint": "17.4.0",
    "stylelint-config-prettier": "9.0.5",
    "stylelint-config-standard": "40.0.0",
    "stylelint-config-styled-components": "0.1.1",
    "stylelint-processor-styled-components": "1.10.0"
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not op_mini all"
  ],
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "stylelint --fix"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
